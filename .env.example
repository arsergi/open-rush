# Port the app listens on.
PORT=3000

# Required. A long, random secret used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Directory for the SQLite DB file and uploaded photos.
DATA_DIR=./data

# Set to 1 when serving over HTTPS (e.g. behind a TLS-terminating reverse
# proxy) so session cookies get the Secure flag. Leave unset for local HTTP.
COOKIE_SECURE=

# Set to 1 when running behind a reverse proxy (nginx/Caddy) so rate limiting sees real client IPs
TRUST_PROXY=
