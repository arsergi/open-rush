<%- include('../partials/head', { title: 'Sign up' }) %>
<%- include('../partials/nav') %>
<main class="container">
  <h1>Sign up</h1>
  <% if (signupsClosed) { %>
    <p class="notice">Signups are currently closed. Please contact a chapter admin.</p>
  <% } else { %>
    <% if (error) { %><p class="error"><%= error %></p><% } %>
    <form method="POST" action="/signup">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Email
        <input type="email" name="email" value="<%= values.email %>" required>
      </label>
      <label>Username
        <input type="text" name="username" value="<%= values.username %>" required minlength="3" maxlength="30" pattern="[a-zA-Z0-9_]+">
      </label>
      <label>Password
        <input type="password" name="password" required minlength="8">
      </label>
      <button type="submit">Sign up</button>
    </form>
  <% } %>
  <p><a href="/login">Already have an account? Log in</a></p>
</main>
<%- include('../partials/foot') %>
